  42:Core/Src/main.c **** 
  43:Core/Src/main.c **** /* PWM brake servo — TIM2 CH1 (PA0), µs direct */
  44:Core/Src/main.c **** /* Physical inversion: 1900µs = rod extended = brake OFF, 1100µs = rod retracted = brake ON */
  45:Core/Src/main.c **** #define PWM_SERVO_MIN_US      1100     /* full brake ON */
  46:Core/Src/main.c **** #define PWM_SERVO_MAX_US      1900     /* brake OFF */
  47:Core/Src/main.c **** #define PWM_FAILSAFE_US       1150     /* failsafe → brake ON */
  48:Core/Src/main.c **** 
  49:Core/Src/main.c **** /* PWM gear servo — TIM2 CH2 (PA1), µs direct */
  50:Core/Src/main.c **** #define PWM_GEAR_MIN_US       1100
  51:Core/Src/main.c **** #define PWM_GEAR_MAX_US       1900
  52:Core/Src/main.c **** #define PWM_GEAR_FAILSAFE_US  1500     /* failsafe → neutral */
  53:Core/Src/main.c **** 
  54:Core/Src/main.c **** #define PWM_PERIOD_US    20000    /* 50 Hz = 20ms period */
  55:Core/Src/main.c **** #define PWM_MAX_CCR      999      /* TIM2 counter period */
  56:Core/Src/main.c **** /* USER CODE END PD */
