 142:Core/Src/main.c **** /*
 143:Core/Src/main.c ****  * Resynchronizing frame parser.
 144:Core/Src/main.c ****  *
 145:Core/Src/main.c ****  *   PS_SYNC1   : hunt for 0xAA. Anything else is discarded.
 146:Core/Src/main.c ****  *   PS_SYNC2   : saw 0xAA, expect 0x55. If another 0xAA arrives, stay here
 147:Core/Src/main.c ****  *                (it might be the real start). Any other byte -> hunt again.
 148:Core/Src/main.c ****  *   PS_PAYLOAD : collect 9 bytes. When full, verify CRC over the first 8.
 149:Core/Src/main.c ****  *                On success, update rc and mark link_ok. On CRC failure,
 150:Core/Src/main.c ****  *                discard and resync — a spurious 0xAA 0x55 only costs one frame.
 151:Core/Src/main.c ****  */
 152:Core/Src/main.c **** static void parser_feed(uint8_t b) {
 153:Core/Src/main.c ****     switch (pstate) {
 154:Core/Src/main.c ****     case PS_SYNC1:
 155:Core/Src/main.c ****         if (b == SYNC1) pstate = PS_SYNC2;
 156:Core/Src/main.c ****         break;
 157:Core/Src/main.c **** 
 158:Core/Src/main.c ****     case PS_SYNC2:
 159:Core/Src/main.c ****         if (b == SYNC2)      { pstate = PS_PAYLOAD; pidx = 0; }
 160:Core/Src/main.c ****         else if (b != SYNC1) { pstate = PS_SYNC1; }
 161:Core/Src/main.c ****         break;
 162:Core/Src/main.c **** 
 163:Core/Src/main.c ****     case PS_PAYLOAD:
 164:Core/Src/main.c ****         payload[pidx++] = b;
 165:Core/Src/main.c ****         if (pidx == (FRAME_LEN - 2)) {
 166:Core/Src/main.c ****             uint8_t crc_calc = crc8_dallas(payload, 8);
 167:Core/Src/main.c ****             uint8_t crc_rx   = payload[8];
ARM GAS  C:\Users\bulli\AppData\Local\Temp\ccgdAJmu.s 			page 9


 168:Core/Src/main.c ****             if (crc_calc == crc_rx) {
 169:Core/Src/main.c ****                 rc.ch1 = (uint16_t)payload[0] | ((uint16_t)payload[1] << 8);
 170:Core/Src/main.c ****                 rc.ch2 = (uint16_t)payload[2] | ((uint16_t)payload[3] << 8);
 171:Core/Src/main.c ****                 rc.ch3 = (uint16_t)payload[4] | ((uint16_t)payload[5] << 8);
 172:Core/Src/main.c ****                 rc.ch4 = (uint16_t)payload[6] | ((uint16_t)payload[7] << 8);
 173:Core/Src/main.c ****                 rc.last_frame_tick = HAL_GetTick();
 174:Core/Src/main.c ****                 rc.link_ok = 1;
 175:Core/Src/main.c ****                 update_servo_pwm(rc.ch1);  /* update servo position */
 176:Core/Src/main.c ****             }
 177:Core/Src/main.c ****             pstate = PS_SYNC1;
 178:Core/Src/main.c ****         }
 179:Core/Src/main.c ****         break;
 180:Core/Src/main.c ****     }
 181:Core/Src/main.c **** }
