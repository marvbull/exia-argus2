 150:Core/Src/main.c **** /*
 151:Core/Src/main.c ****  * Resynchronizing frame parser.
 152:Core/Src/main.c ****  *
 153:Core/Src/main.c ****  *   PS_SYNC1   : hunt for 0xAA. Anything else is discarded.
 154:Core/Src/main.c ****  *   PS_SYNC2   : saw 0xAA, expect 0x55. If another 0xAA arrives, stay here
 155:Core/Src/main.c ****  *                (it might be the real start). Any other byte -> hunt again.
 156:Core/Src/main.c ****  *   PS_PAYLOAD : collect 9 bytes. When full, verify CRC over the first 8.
 157:Core/Src/main.c ****  *                On success, update rc and mark link_ok. On CRC failure,
 158:Core/Src/main.c ****  *                discard and resync — a spurious 0xAA 0x55 only costs one frame.
 159:Core/Src/main.c ****  */
 160:Core/Src/main.c **** static void parser_feed(uint8_t b) {
 161:Core/Src/main.c ****     switch (pstate) {
 162:Core/Src/main.c ****     case PS_SYNC1:
 163:Core/Src/main.c ****         if (b == SYNC1) pstate = PS_SYNC2;
 164:Core/Src/main.c ****         break;
 165:Core/Src/main.c **** 
 166:Core/Src/main.c ****     case PS_SYNC2:
 167:Core/Src/main.c ****         if (b == SYNC2)      { pstate = PS_PAYLOAD; pidx = 0; }
ARM GAS  C:\Users\bulli\AppData\Local\Temp\ccMLKjFn.s 			page 9


 168:Core/Src/main.c ****         else if (b != SYNC1) { pstate = PS_SYNC1; }
 169:Core/Src/main.c ****         break;
 170:Core/Src/main.c **** 
 171:Core/Src/main.c ****     case PS_PAYLOAD:
 172:Core/Src/main.c ****         payload[pidx++] = b;
 173:Core/Src/main.c ****         if (pidx == (FRAME_LEN - 2)) {
 174:Core/Src/main.c ****             uint8_t crc_calc = crc8_dallas(payload, 8);
 175:Core/Src/main.c ****             uint8_t crc_rx   = payload[8];
 176:Core/Src/main.c ****             if (crc_calc == crc_rx) {
 177:Core/Src/main.c ****                 rc.ch1 = (uint16_t)payload[0] | ((uint16_t)payload[1] << 8);
 178:Core/Src/main.c ****                 rc.ch2 = (uint16_t)payload[2] | ((uint16_t)payload[3] << 8);
 179:Core/Src/main.c ****                 rc.ch3 = (uint16_t)payload[4] | ((uint16_t)payload[5] << 8);
 180:Core/Src/main.c ****                 rc.ch4 = (uint16_t)payload[6] | ((uint16_t)payload[7] << 8);
 181:Core/Src/main.c ****                 rc.last_frame_tick = HAL_GetTick();
 182:Core/Src/main.c ****                 rc.link_ok = 1;
 183:Core/Src/main.c ****                 update_servo_pwm(rc.ch1);
 184:Core/Src/main.c ****                 update_gear_pwm(rc.ch3);
 185:Core/Src/main.c ****             }
 186:Core/Src/main.c ****             pstate = PS_SYNC1;
 187:Core/Src/main.c ****         }
 188:Core/Src/main.c ****         break;
 189:Core/Src/main.c ****     }
 190:Core/Src/main.c **** }
