 183:Core/Src/main.c **** /*
 184:Core/Src/main.c ****  * Map CH1 (0..2047) to servo PWM pulse width.
 185:Core/Src/main.c ****  * Observed behavior: 1900µs = extended, 1100µs = retracted
 186:Core/Src/main.c ****  * Desired: CH1 300 (low) = retracted, CH1 1600 (high) = extended
 187:Core/Src/main.c ****  * So: CH1 300 → 1100µs, CH1 1600 → 1900µs
 188:Core/Src/main.c ****  */
